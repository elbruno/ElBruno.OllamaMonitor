<Window x:Class="ElBruno.OllamaMonitor.MiniMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ollama Mini Monitor"
        Width="280"
        Height="220"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Border Background="#D91F2937"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            CornerRadius="16"
            Padding="14"
            MouseLeftButtonDown="OnWindowDrag">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Ollama Mini Monitor"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="16" />
                    <TextBlock Text="Always on top"
                               Foreground="#FFD1D5DB"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Click="OnCloseClicked"
                        Width="28"
                        Height="28"
                        FontSize="14"
                        FontWeight="Bold"
                        Content="×"
                        Background="#33FFFFFF"
                        Foreground="White"
                        BorderBrush="#00FFFFFF"
                        Cursor="Hand" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding StateText}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,14,0,0" />

            <StackPanel Grid.Row="2"
                        Margin="0,14,0,0">
                <TextBlock Text="{Binding PrimaryModelText}"
                           Foreground="#FFF3F4F6"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding CpuText}"
                           Foreground="#FFF3F4F6"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding MemoryText}"
                           Foreground="#FFF3F4F6"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding CompactGpuText}"
                           Foreground="#FFF3F4F6"
                           TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Text="{Binding LastCheckedText}"
                       Foreground="#FFD1D5DB"
                       HorizontalAlignment="Right"
                       Margin="0,8,0,0" />
        </Grid>
    </Border>
</Window>
