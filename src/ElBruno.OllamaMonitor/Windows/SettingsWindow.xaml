<Window x:Class="ElBruno.OllamaMonitor.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings - Ollama Monitor"
        Width="500"
        Height="580"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="../Assets/TrayIcons/tray-green.ico"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF374151"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF6B7280"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="EditableFieldStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="ReadOnlyFieldStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFE5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFF9FAFB"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Application Settings" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,12"/>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Tier 1: Editable Settings -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Connection"/>
                
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Endpoint *"/>
                <TextBox x:Name="EndpointTextBox" 
                         Style="{StaticResource EditableFieldStyle}"
                         ToolTip="The base URL of your Ollama API endpoint (e.g., http://localhost:11434)"/>
                <TextBlock x:Name="EndpointErrorText" 
                           Foreground="#FFDC2626" 
                           FontSize="11" 
                           Margin="0,2,0,0" 
                           Visibility="Collapsed"/>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Refresh Interval (seconds) *"/>
                <TextBox x:Name="RefreshIntervalTextBox" 
                         Style="{StaticResource EditableFieldStyle}"
                         ToolTip="How often to refresh Ollama status (1-60 seconds)"/>
                <TextBlock x:Name="RefreshIntervalErrorText" 
                           Foreground="#FFDC2626" 
                           FontSize="11" 
                           Margin="0,2,0,0" 
                           Visibility="Collapsed"/>

                <!-- Tier 2: Read-Only Settings (Phase 2b+ editable) -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Application Behavior"/>
                
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Start Minimized to Tray"/>
                <CheckBox x:Name="StartMinimizedCheckBox" 
                          IsEnabled="False" 
                          Margin="0,4,0,0"
                          ToolTip="Read-only (editable in future release)"/>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Show Floating Window on Start"/>
                <CheckBox x:Name="ShowFloatingWindowCheckBox" 
                          IsEnabled="False" 
                          Margin="0,4,0,0"
                          ToolTip="Read-only (editable in future release)"/>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Metrics Collection"/>
                
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Enable GPU Metrics"/>
                <CheckBox x:Name="EnableGpuMetricsCheckBox" 
                          IsEnabled="False" 
                          Margin="0,4,0,0"
                          ToolTip="Read-only (editable in future release)"/>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Enable Disk Metrics"/>
                <CheckBox x:Name="EnableDiskMetricsCheckBox" 
                          IsEnabled="False" 
                          Margin="0,4,0,0"
                          ToolTip="Read-only (editable in future release)"/>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Alert Thresholds"/>
                
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="High CPU Threshold (%)"/>
                <TextBox x:Name="HighCpuThresholdTextBox" 
                         Style="{StaticResource ReadOnlyFieldStyle}"/>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="High Memory Threshold (GB)"/>
                <TextBox x:Name="HighMemoryThresholdTextBox" 
                         Style="{StaticResource ReadOnlyFieldStyle}"/>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="High GPU Threshold (%)"/>
                <TextBox x:Name="HighGpuThresholdTextBox" 
                         Style="{StaticResource ReadOnlyFieldStyle}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Note -->
        <Border Grid.Row="2" 
                Background="#FFFFFBEB" 
                BorderBrush="#FFFBBF24" 
                BorderThickness="1" 
                CornerRadius="4" 
                Padding="12" 
                Margin="0,12,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" 
                           FontSize="14" 
                           Foreground="#FFFBBF24" 
                           Margin="0,0,8,0"/>
                <TextBlock Text="Restart required for changes to take effect." 
                           FontSize="11" 
                           Foreground="#FF92400E" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button x:Name="ResetButton" 
                    Content="Reset to Defaults" 
                    Width="130" 
                    Height="32" 
                    Margin="0,0,8,0" 
                    Click="OnResetClicked"/>
            <Button x:Name="CancelButton" 
                    Content="Cancel" 
                    Width="80" 
                    Height="32" 
                    Margin="0,0,8,0" 
                    Click="OnCancelClicked"/>
            <Button x:Name="SaveButton" 
                    Content="Save" 
                    Width="80" 
                    Height="32" 
                    Click="OnSaveClicked" 
                    IsDefault="True"
                    Background="#FF3B82F6" 
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
