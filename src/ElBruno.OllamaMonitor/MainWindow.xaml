<Window x:Class="ElBruno.OllamaMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ElBruno.OllamaMonitor - Details"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="480"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Icon="Assets/TrayIcons/tray-green.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0"
                        Padding="14,6" />
                <Button Content="Copy Status"
                        Command="{Binding CopyStatusCommand}"
                        Margin="0,0,8,0"
                        Padding="14,6" />
                <Button Content="Open API"
                        Command="{Binding OpenEndpointCommand}"
                        Margin="0,0,8,0"
                        Padding="14,6" />
                <Button Content="Minimize to Tray"
                        Command="{Binding HideWindowCommand}"
                        Padding="14,6" />
            </StackPanel>

            <TextBlock Text="Closing this window keeps the app running in the system tray."
                       HorizontalAlignment="Right"
                       Foreground="#FF6B7280"
                       Margin="0,8,0,0" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#FF1F2937"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Ollama Status"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="{Binding StateText}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Endpoint}"
                                       Foreground="#FFD1D5DB"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="Last checked"
                                       Foreground="#FFD1D5DB"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding LastCheckedText}"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Right"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding VersionText}"
                                       Foreground="#FFD1D5DB"
                                       HorizontalAlignment="Right"
                                       Margin="0,16,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorText}"
                               Foreground="#FF991B1B"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Runtime"
                              Margin="0,0,8,0">
                        <StackPanel Margin="8">
                            <TextBlock Text="{Binding ApiReachableText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding ProcessStatusText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding CpuText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding MemoryText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding PrivateMemoryText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding DiskReadText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding DiskWriteText}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="GPU"
                              Grid.Column="1"
                              Margin="8,0,0,0">
                        <StackPanel Margin="8">
                            <TextBlock Text="{Binding GpuText}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding GpuMemoryText}" />
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <GroupBox Header="Loaded Models">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ModelsSummaryText}"
                                   Margin="0,0,0,8" />
                        <ListView ItemsSource="{Binding Models}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name"
                                                    Width="260"
                                                    DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Size"
                                                    Width="120"
                                                    DisplayMemberBinding="{Binding Size}" />
                                    <GridViewColumn Header="Processor"
                                                    Width="140"
                                                    DisplayMemberBinding="{Binding Processor}" />
                                    <GridViewColumn Header="Expires"
                                                    Width="160"
                                                    DisplayMemberBinding="{Binding ExpiresAtDisplay}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
