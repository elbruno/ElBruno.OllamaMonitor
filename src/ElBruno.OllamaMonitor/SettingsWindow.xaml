<Window x:Class="ElBruno.OllamaMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings - ElBruno.OllamaMonitor"
        Width="600"
        Height="750"
        MinWidth="600"
        MinHeight="700"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Icon="Assets/TrayIcons/tray-green.ico"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A"
        Foreground="#FFFFFF">
    <DockPanel LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#1E293B"
                Padding="20,15">
            <StackPanel Margin="0">
                <TextBlock Text="Settings"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           Margin="0" />
                <TextBlock Text="Configure notifications and application behavior"
                           FontSize="12"
                           Foreground="#94A3B8"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <!-- Buttons Footer -->
        <Border DockPanel.Dock="Bottom"
                Background="#1E293B"
                Padding="20,15">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CloseButton"
                        Content="Close"
                        Click="CloseButton_Click"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        Background="#64748B"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand" />
                <Button x:Name="SaveButton"
                        Content="Save Settings"
                        Click="SaveButton_Click"
                        Padding="20,10"
                        Background="#3B82F6"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand" />
            </StackPanel>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0F172A"
                      Padding="20,20,20,20">
            <StackPanel>
                <!-- Notifications Section -->
                <GroupBox Header="📢 Notifications"
                          Background="#1E293B"
                          Foreground="#FFFFFF"
                          Margin="0,0,0,20"
                          Padding="15">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="13" />
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <StackPanel>
                        <CheckBox x:Name="EnableNotificationsCheckBox"
                                  Content="Enable Windows Notifications"
                                  IsChecked="{Binding EnableNotifications}"
                                  Foreground="#E2E8F0"
                                  Margin="0,0,0,15"
                                  FontSize="13"
                                  Cursor="Hand" />

                        <TextBlock Text="Event Types:"
                                   Foreground="#CBD5E1"
                                   Margin="0,10,0,10"
                                   FontSize="12"
                                   FontWeight="Bold" />

                        <!-- Ollama Events -->
                        <Border Background="#0F172A"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,15"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Ollama Status"
                                           Foreground="#CBD5E1"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,10" />
                                <CheckBox x:Name="OllamaOfflineCheckBox"
                                          Content="🔴 Ollama goes offline"
                                          IsChecked="{Binding NotifyOllamaOffline}"
                                          Foreground="#E2E8F0"
                                          Margin="0,0,0,8"
                                          FontSize="12"
                                          Cursor="Hand" />
                                <CheckBox x:Name="OllamaOnlineCheckBox"
                                          Content="🟢 Ollama comes back online"
                                          IsChecked="{Binding NotifyOllamaOnline}"
                                          Foreground="#E2E8F0"
                                          FontSize="12"
                                          Cursor="Hand" />
                            </StackPanel>
                        </Border>

                        <!-- Model Events -->
                        <Border Background="#0F172A"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,15"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Model Events"
                                           Foreground="#CBD5E1"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,10" />
                                <CheckBox x:Name="ModelLoadedCheckBox"
                                          Content="📦 Model is loaded"
                                          IsChecked="{Binding NotifyModelLoaded}"
                                          Foreground="#E2E8F0"
                                          Margin="0,0,0,8"
                                          FontSize="12"
                                          Cursor="Hand" />
                                <CheckBox x:Name="ModelUnloadedCheckBox"
                                          Content="📭 Model is unloaded"
                                          IsChecked="{Binding NotifyModelUnloaded}"
                                          Foreground="#E2E8F0"
                                          FontSize="12"
                                          Cursor="Hand" />
                            </StackPanel>
                        </Border>

                        <!-- Resource Events -->
                        <Border Background="#0F172A"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,15"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Resource Usage Alerts"
                                           Foreground="#CBD5E1"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,10" />
                                <CheckBox x:Name="HighCpuCheckBox"
                                          Content="⚠️  High CPU usage"
                                          IsChecked="{Binding NotifyHighCpu}"
                                          Foreground="#E2E8F0"
                                          Margin="0,0,0,8"
                                          FontSize="12"
                                          Cursor="Hand" />
                                <CheckBox x:Name="HighMemoryCheckBox"
                                          Content="⚠️  High memory usage"
                                          IsChecked="{Binding NotifyHighMemory}"
                                          Foreground="#E2E8F0"
                                          Margin="0,0,0,8"
                                          FontSize="12"
                                          Cursor="Hand" />
                                <CheckBox x:Name="HighGpuCheckBox"
                                          Content="⚠️  High GPU usage"
                                          IsChecked="{Binding NotifyHighGpu}"
                                          Foreground="#E2E8F0"
                                          FontSize="12"
                                          Cursor="Hand" />
                            </StackPanel>
                        </Border>

                        <!-- Debounce Setting -->
                        <StackPanel Margin="0,10,0,15">
                            <TextBlock Text="Notification Debounce (seconds)"
                                       Foreground="#CBD5E1"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="DebounceSlider"
                                        Width="300"
                                        Minimum="5"
                                        Maximum="300"
                                        Value="{Binding NotificationDebounceSeconds, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Background="#1E293B"
                                        Foreground="#3B82F6"
                                        Margin="0,0,15,0"
                                        VerticalAlignment="Center" />
                                <TextBlock x:Name="DebounceValueBlock"
                                           Text="{Binding NotificationDebounceSeconds}"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           Width="50"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock Text="sec"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Prevents duplicate notifications for the same event within this time window"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- General Section -->
                <GroupBox Header="⚙️  General"
                          Background="#1E293B"
                          Foreground="#FFFFFF"
                          Padding="15">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="13" />
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <StackPanel>
                        <CheckBox x:Name="StartMinimizedCheckBox"
                                  Content="Start minimized to tray"
                                  IsChecked="{Binding StartMinimizedToTray}"
                                  Foreground="#E2E8F0"
                                  Margin="0,0,0,12"
                                  FontSize="12"
                                  Cursor="Hand" />
                        <CheckBox x:Name="ShowFloatingCheckBox"
                                  Content="Show floating mini monitor on start"
                                  IsChecked="{Binding ShowFloatingWindowOnStart}"
                                  Foreground="#E2E8F0"
                                  FontSize="12"
                                  Cursor="Hand" />
                    </StackPanel>
                </GroupBox>

                <!-- Spacing for ScrollViewer -->
                <TextBlock Margin="0,0,0,20" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
