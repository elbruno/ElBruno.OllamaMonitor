<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Brushes -->
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="#0E639C"/>
    <SolidColorBrush x:Key="ThemePanelBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#374151"/>
    <SolidColorBrush x:Key="ThemeSecondaryForegroundBrush" Color="#D1D5DB"/>

    <!-- Button Styles -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#0E639C"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0E639C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#107EBA"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- GroupBox Styles -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Background" Value="#0F172A"/>
        <Setter Property="BorderBrush" Value="#1F2937"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Window Styles -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="#0F172A"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

</ResourceDictionary>
